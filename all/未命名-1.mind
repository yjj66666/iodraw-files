{"root":{"data":{"id":"dhue61w9im80","created":1776323611981,"text":"中心主题"},"children":[{"data":{"text":"问题背景与感知边界界定","layout":null},"children":[{"data":{"text":"问题背景：星地网络长时延与高并发特性导致传统终端周期性全量上报造成馈电链路严重拥塞","layout":null},"children":[]},{"data":{"text":"核心目的：为组播调度的用户聚类和链路重构提供准静态与动态特征支撑","layout":null},"children":[]},{"data":{"text":"边界限定：仅采集影响组播承载分配的强相关数据（可用带宽、时延、QoE需求）","layout":null},"children":[]},{"data":{"text":"不干预范围：底层瞬时丢包的去中心化局域自愈（确保职能解耦与低时延运转）","layout":null},"children":[]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}