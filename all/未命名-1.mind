{"root":{"data":{"id":"dhue61w9im80","created":1776323611981,"text":"中心主题"},"children":[{"data":{"text":"问题背景与感知边界界定","layout":null},"children":[{"data":{"text":"问题背景：星地网络长时延与高并发特性导致传统终端周期性全量上报造成馈电链路严重拥塞","layout":null},"children":[]},{"data":{"text":"核心目的：为组播调度的用户聚类和链路重构提供准静态与动态特征支撑","layout":null},"children":[]},{"data":{"text":"边界限定：仅采集影响组播承载分配的强相关数据（可用带宽、时延、QoE需求）","layout":null},"children":[]},{"data":{"text":"不干预范围：底层瞬时丢包的去中心化局域自愈（确保职能解耦与低时延运转）","layout":null},"children":[]}]},{"data":{"text":"摘要：核心机制与成果概述","layout":null},"children":[{"data":{"text":"核心问题：星地融合网络中高动态拓扑与海量并发终端导致的“感知信令风暴”","layout":null},"children":[]},{"data":{"text":"解决方案核心机制：“云端先验预演 + 边缘增量汇聚”多维态势感知机制","layout":null},"children":[]},{"data":{"text":"机制特点：剥离底层瞬时补偿数据，服务上层组播调度","layout":null},"children":[]},{"data":{"text":"核心网侧：基于轨道力学先验模型进行确定性拓扑预演，免除常态化拓扑上报","layout":null},"children":[]},{"data":{"text":"边缘侧：SG-SANC节点作为汇聚代理，通过唯一锚定与信令跨层复用，将海量终端需求打包为标准化ST-Vector","layout":null},"children":[]},{"data":{"text":"方案优势：极低信令开销、受限算力下实现高精度资源调度与组播树重构的数据底座","layout":null},"children":[]}]},{"data":{"text":"核心网络实体与动态从属关系定义（工程定义）","layout":null},"children":[{"data":{"text":"1. 节点与终端的物理界定","layout":null},"children":[{"data":{"text":"节点（SG-SANC）：具备资源路由与汇聚能力（如再生载荷卫星、信关站）","layout":null},"children":[]},{"data":{"text":"终端（UE）：产生业务需求且受限于功耗的实体","layout":null},"children":[]}]},{"data":{"text":"2. 唯一动态锚定机制（防止数据幻影）","layout":null},"children":[{"data":{"text":"锚定机制：基于5G NTN协议栈RACH与RRC，终端感知信令仅向唯一“主服务SG-SANC节点”汇报","layout":null},"children":[]},{"data":{"text":"切换机制：终端触发Handover时，特征数据从原节点注销并动态注册至新节点管理域，确保全网视图唯一性","layout":null},"children":[]}]},{"data":{"text":"3. 星地一体化状态向量（ST-Vector）：统一的多维感知数据结构","layout":null},"children":[{"data":{"text":"空间几何维度：节点瞬时位置、终端相对仰角","layout":null},"children":[]},{"data":{"text":"物理链路维度：实测可用带宽、长周期多普勒频移趋势","layout":null},"children":[]},{"data":{"text":"协同资源维度：SG-SANC的有效空闲缓存区大小","layout":null},"children":[]},{"data":{"text":"负载子集：该节点辖区内所锚定的各终端ID及精细化QoE需求","layout":null},"children":[]}]}]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}